{
  "name": "@webfeedback/widget",
  "version": "1.0.0",
  "description": "Drop-in feedback widget — bug reports, feature requests, and ratings with automatic screenshots",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    },
    "./widget.js": "./dist/widget.global.js"
  },
  "peerDependencies": {
    "@types/react": ">=18",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": true,
  "scripts": {
    "build": "tsup",
    "build:copy": "tsup && cp dist/widget.global.js ../backend/public/widget.js",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "feedback",
    "widget",
    "web-component",
    "bug-report",
    "screenshot",
    "shadow-dom"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
