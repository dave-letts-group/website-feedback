generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sites     Site[]
  admins    Admin[]
  invites   Invite[]
}

model Site {
  id           String     @id @default(cuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  name         String
  domain       String?
  siteKey      String     @unique @default(cuid())
  notionApiKey String?
  notionDbId   String?
  notionEnabled Boolean @default(true)
  githubToken  String?
  githubRepo   String?
  githubEnabled Boolean @default(true)
  webhookUrl   String?
  webhookToken String?
  webhookEnabled Boolean @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  feedback     Feedback[]
  apiKeys      ApiKey[]

  @@index([tenantId])
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  name         String?
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  role         String   @default("member")
  isSuperAdmin Boolean  @default(false)
  createdAt    DateTime @default(now())
  invites      Invite[]
}

model Invite {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  email       String
  role        String    @default("member")
  token       String    @unique @default(cuid())
  expiresAt   DateTime
  invitedById String
  invitedBy   Admin     @relation(fields: [invitedById], references: [id])
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([tenantId])
  @@index([token])
}

model Feedback {
  id             String   @id @default(cuid())
  siteId         String
  site           Site     @relation(fields: [siteId], references: [id])
  tenantId       String
  pageTitle      String?
  pageId         String?
  pageUrl        String?
  urlParams      Json?
  userId         String?
  userName       String?
  message        String
  category       String   @default("general")
  rating         Int?
  screenshot     String?  @db.Text
  metadata       Json?
  userAgent      String?
  sourceDomain   String?
  status         String   @default("New")
  notionPageId   String?
  githubIssueUrl String?
  createdAt      DateTime @default(now())

  @@index([siteId, status])
  @@index([siteId, createdAt])
  @@index([tenantId, createdAt])
}

model ApiKey {
  id          String   @id @default(cuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  tenantId    String
  name        String
  key         String   @unique
  permissions String[]
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime?

  @@index([key])
  @@index([siteId])
  @@index([tenantId])
}
